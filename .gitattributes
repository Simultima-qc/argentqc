# Normalize text line endings to LF in the repository.
* text=auto eol=lf

# Explicit text files.
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
